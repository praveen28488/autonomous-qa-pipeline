# Non-secret agent configuration — safe to commit
# ── Infrastructure ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
CHROMA_URL=http://localhost:8000
GITHUB_MCP_URL=http://localhost:8811/sse
JIRA_MCP_URL=http://localhost:8812/sse
JIRA_PROJECT_KEY=QA

# ── LLM (Gemini via OpenAI-compatible endpoint — free tier) ──
# NOTE: spec originally used claude-sonnet-4-20250514 + @anthropic-ai/sdk.
# We substitute Google Gemini (free) via the OpenAI-compatible API.
# GEMINI_API_KEY must be set as a real secret (not committed here).
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_TOKENS=4096

# ── Orchestrator tuning ───────────────────────────────────────
ORCHESTRATOR_HEARTBEAT_MS=10000
AGENT_CIRCUIT_BREAKER_THRESHOLD=3
AGENT_MAX_RETRIES=3
REDIS_CHANNEL_PREFIX=agents
MCP_HEALTH_CHECK_INTERVAL_MS=30000
LOG_LEVEL=info

# ── Playwright / CI ──────────────────────────────────────────
PW_TEST_SHARD_COUNT=4
PW_TIMEOUT_MS=30000
PW_RETRY_COUNT=0

# ── Requirements Agent thresholds ────────────────────────────
REQUIREMENTS_QUALITY_THRESHOLD_INGEST=70
REQUIREMENTS_QUALITY_THRESHOLD_WARN=40
REQUIREMENTS_MAX_STORIES_PER_RUN=100
REQUIREMENTS_OUTPUT_PATH=test-scenarios.json
